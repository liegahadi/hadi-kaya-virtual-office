# ============================================================
# HADI KAYA WA-BOT — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values.
# Each agent needs its own:
#   - ${NAME}_WHATSAPP (agent's WA number)
#   - ${NAME}_GROUP_JID (group JID where agent participates)
# Agent is ENABLED only if its WHATSAPP env var is set.
# ============================================================

# === COMMON (shared by all agents) ===
OWNER_WHATSAPP=628117176687
VERCEL_API_URL=https://hadi-kaya-virtual-office.vercel.app
WORK_START=9
WORK_END=17
PORT=3000

