// ============================================================
// Virtual Office "Menuju Hadi Kaya" - Multi-Agent System
// Database Schema (SQLite for dev, PostgreSQL/Supabase for prod)
// ============================================================
// Notes:
// - DEV: SQLite (local) — fast iteration
// - PROD: PostgreSQL via Supabase (deploy to Vercel)
// - All timestamps in UTC
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. AUTH & USERS
// ============================================================

model AppUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("OWNER") // OWNER | ADMIN | VIEWER
  phone        String?
  avatar       String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  approvals      Approval[]
  fundRequests   FundRequest[]
  documents      Document[]
  auditLogs      AuditLog[]
  settings       UserSetting[]
}

// Google OAuth tokens - untuk akses Google Drive & Docs API sebagai user (bukan Service Account)
// Owner login sekali → refresh_token disimpan → sistem bisa akses Drive kapan saja
// Untuk MVP: 1 token global (single owner, app belum ada login system)
model GoogleToken {
  id              String   @id @default("owner") // hardcoded "owner" for MVP single-user
  accessToken     String
  refreshToken    String
  expiryDate      DateTime? // when access token expires
  tokenType       String   @default("Bearer")
  scope           String
  email           String?  // email Google account yang login
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Track Google Docs created per customer
// Setiap doc yang dibuat via sistem disimpan di sini + di Google Drive folder customer
model GoogleDoc {
  id          String   @id @default(cuid())
  docId       String   @unique // Google Doc ID (from Drive)
  customerId  String?  // link to Customer
  fileName    String
  folderId    String?  // Google Drive folder ID (customer folder)
  docType     String   @default("sk-slip-gaji") // sk-slip-gaji | spr | flpp | etc
  editUrl     String
  templateId  String?  // which template was used
  createdAt   DateTime @default(now())

  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

model UserSetting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ============================================================
// 2. PROJECTS & UNITS (Real Estate)
// ============================================================

model Project {
  id          String   @id @default(cuid())
  name        String   // e.g. "Anjayo 16"
  brandName   String   // e.g. "Anjayo"
  code        String?  // e.g. "A16"
  location    String   // e.g. "Jerambah Gantung, Pangkalpinang"
  address     String?
  totalUnits  Int      @default(0)
  sitePlanUrl String?  // image URL (jpg/png/pdf)
  status      String   @default("ACTIVE") // ACTIVE | COMPLETED | PAUSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units        Unit[]
  rabs         RAB[]
  rabLines     RABLine[]
  materialStock MaterialStock[]
  agentTeams   AgentTeam[]
  customers    Customer[]

  @@unique([name])
}

model Unit {
  id           String   @id @default(cuid())
  projectId    String
  blockNumber  String   // e.g. "A1", "B12"
  unitType     String   @default("36") // type 36, etc
  landSize     Float    // e.g. 84, 105, 127
  buildingSize Float    @default(36)
  price        Float    @default(173000000) // harga jual ke bank
  dpAmount     Float    @default(5000000) // DP per luas tanah
  status       String   @default("AVAILABLE") // AVAILABLE | BOOKED | SOLD | RESERVED
  customerId   String?
  soldAt       DateTime?
  bookedAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customer      Customer?     @relation(fields: [customerId], references: [id])
  materialUsages MaterialUsage[]
  progressPhotos ProgressPhoto[]
  budgetTracking UnitBudgetTracking[]

  @@unique([projectId, blockNumber])
}

// ============================================================
// 3. AGENTS (Multi-Agent System)
// ============================================================

model Agent {
  id            String   @id @default(cuid())
  name          String   // e.g. "RINA", "Ayu", "RATNA"
  role          String   // FINANCE | MATERIAL | DOCUMENT | MARKETING | CONTENT | CTO | CAO
  description   String?
  personality   String?  // personality description
  systemPrompt  String?  // custom system prompt (long)
  gender        String?  // MALE | FEMALE
  avatarUrl     String?
  whatsappNumber String? // unique WA number per agent
  llmModel      String   @default("glm-4.6") // HEAVY task model: complex analysis, decisions, content creation
  llmProvider   String   @default("openrouter") // openrouter | zai | openai | anthropic
  lightLlmModel String?  // LIGHT task model: FAQ, status, simple replies, casual chat (cheap: gemini-flash, gpt-4o-mini)
  lightLlmProvider String? // provider for light model
  llmApiKeyRef  String?  // reference to encrypted key in env/config
  temperature   Float    @default(0.7)
  maxTokens     Int      @default(2000)
  isActive      Boolean  @default(true)
  isDevilsAdvocate Boolean @default(false) // push back mode
  skills        String?  // JSON string of skills list
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  conversations      Conversation[]
  memories           Memory[]
  knowledgeItems     KnowledgeItem[]
  agentTeams         AgentTeamMember[]
  pos                PO[]
  fundRequests       FundRequest[]
  documents          Document[]
  surveySchedules    SurveySchedule[]
  approvals          Approval[]
  assignedCustomers  Customer[]

  @@unique([name, role])
}

model AgentTeam {
  id        String   @id @default(cuid())
  name      String   // e.g. "Tim Anjayo 16", "Tim Proyek B"
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members AgentTeamMember[]
}

model AgentTeamMember {
  id        String   @id @default(cuid())
  teamId    String
  agentId   String
  joinedAt  DateTime @default(now())

  team  AgentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  agent Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([teamId, agentId])
}

// ============================================================
// 4. CUSTOMERS & SALES PIPELINE
// ============================================================

model Customer {
  id           String   @id @default(cuid())
  projectId    String
  name         String
  whatsappNumber String?
  phone        String?
  email        String?
  occupation   String?  // KARYAWAN | WIRAUSAHA | LAINNYA
  maritalStatus String? // SINGLE | MENIKAH | JANDA | DUDA
  monthlyIncome Float?
  hasExistingLoan Boolean @default(false)
  hasExistingHouse Boolean @default(false)
  sourceLead   String?  // FB | IG | TIKTOK | WALK_IN | REFERRAL
  assignedAgentId String? // locked to 1 marketing AI per customer
  personalityPreference String? // cheerful | informatif | manipulatif (for matching)
  stage        String   @default("DM") // DM | SURVEY | CLOSING | BOOKING | SLIK | PEMBERKASAN | SP3K | AKAD | SERAH_TERIMA | LOST
  stageUpdatedAt DateTime?
  notes        String?
  isExistingMigration Boolean @default(false) // konsumen existing yang dimigrasi
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Detailed data for auto-fill (added for BerkasView v2)
  nik          String?
  birthPlace   String?
  birthDate    String?
  gender       String?
  ktpAddress   String?
  rtRw         String?
  kelurahan    String?
  kecamatan    String?
  city         String?
  postalCode   String?
  religion     String?
  companyName  String?
  companyAddress String?
  companyPhone String?
  workDuration String?
  workPosition String?
  bankName     String?
  bankAccount  String?
  npwpNumber   String?
  btnAccountNumber String?
  blockLetter  String?
  houseNumber  String?
  landSize     Int?
  houseSize    Int?
  shmNumber    String?
  nibNumber    String?
  spouseName   String?
  spouseNik    String?
  spouseBirthPlace String?
  spouseBirthDate  String?
  spouseOccupation String?
  spouseAddress String?
  spouseIncome Float?
  motherMaidenName String?
  emergencyContact String?
  dependents   Int?
  dateOfDocument String?
  // Date tracking
  closingDate    DateTime?
  berkasLengkapDate DateTime?
  berkasMasukBankDate DateTime?
  sp3kDate       DateTime?
  akadDate       DateTime?
  akadNumber     String?
  lpaDate        DateTime?
  lpaNumber      String?
  berkasLengkap  Boolean  @default(false)
  atasanName     String?
  atasanNip      String?
  workplaceFrontPhoto String?
  workplaceInsidePhoto String?
  workplaceMapsLink String?
  workplaceMapsShortLink String?  // short link maps.app.goo.gl/... (untuk bank)
  workplaceJamOperasional String?
  workplaceWaktuHubungi String?
  gajiPokok      Int?
  slipGajiData   String?  // JSON: tunjangan, potongan, tanggalTerima, periode
  uploadedDocs   String?  // JSON string of { docId: dataUrl } for file persistence

  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedAgent  Agent?        @relation(fields: [assignedAgentId], references: [id])
  units          Unit[]
  conversations  Conversation[]
  stageHistory   CustomerStageHistory[]
  documents      Document[]
  googleDocs     GoogleDoc[]
  surveySchedules SurveySchedule[]
  bankPipelines  BankPipeline[]

  @@index([projectId, stage])
  @@index([assignedAgentId])
}

model CustomerStageHistory {
  id          String   @id @default(cuid())
  customerId  String
  fromStage   String?
  toStage     String
  changedBy   String?  // agentId | userId
  reason      String?
  changedAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ============================================================
// 5. CONVERSATIONS & MESSAGES (WhatsApp + Dashboard chat)
// ============================================================

model Conversation {
  id          String   @id @default(cuid())
  customerId  String?
  agentId     String?
  channel     String   @default("WHATSAPP") // WHATSAPP | DASHBOARD | INSTAGRAM | FACEBOOK | TIKTOK
  status      String   @default("ACTIVE") // ACTIVE | ARCHIVED | CLOSED
  summary     String?  // AI-generated summary
  lastMessageAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  agent    Agent?    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([customerId, agentId])
  @@index([lastMessageAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // CUSTOMER | AGENT | SYSTEM | OWNER
  content        String
  contentType    String   @default("TEXT") // TEXT | IMAGE | AUDIO | DOCUMENT | LOCATION | STICKER
  mediaUrl       String?
  metadata       String?  // JSON string
  isRead         Boolean  @default(false)
  needsApproval  Boolean  @default(false) // for actions requiring owner sign-off
  approvalStatus String?  // PENDING | APPROVED | REJECTED
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ============================================================
// 6. MEMORY LAYER (Central Brain + Per-Agent Memory)
// ============================================================

model Memory {
  id          String   @id @default(cuid())
  agentId     String?  // null = shared central brain
  customerId  String?  // customer-specific memory (per-customer personality lock)
  category    String   // FACT | PREFERENCE | INTERACTION | DECISION | CONTEXT
  content     String
  importance  Float    @default(0.5) // 0.0 - 1.0
  embedding   String?  // vector embedding (will use pgvector on Postgres)
  source      String?  // CONVERSATION | MANUAL | INFERRED
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent Agent? @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, category])
  @@index([customerId])
}

// ============================================================
// 7. KNOWLEDGE BASE (FAQ, Objection, RAB, Templates, etc)
// ============================================================

model KnowledgeItem {
  id          String   @id @default(cuid())
  agentId     String?  // null = global knowledge, available to all agents
  category    String   // FAQ | OBJECTION | PRODUCT_INFO | BANK_REQUIREMENT | RAB_DETAIL | SELLING_POINT | COMPANY_POLICY
  question    String?  // for FAQ/objection
  answer      String?  // for FAQ/objection
  content     String?  // for general knowledge (markdown)
  tags        String?  // JSON array of tags
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent Agent? @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([category, isActive])
  @@index([agentId])
}

// ============================================================
// 8. APPROVALS (Owner sign-off workflow)
// ============================================================

model Approval {
  id          String   @id @default(cuid())
  requesterAgentId String
  approverUserId String?
  type        String   // PO | FUND_REQUEST | PAYMENT | DOCUMENT_SIGN | POST_PUBLISH
  referenceId String?  // ID of related entity (PO, FundRequest, etc)
  payload     String   // JSON string of what needs approval
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED | EXPIRED
  signatureUrl String? // digital signature or photo of physical sign
  notes       String?
  respondedAt DateTime?
  createdAt   DateTime @default(now())

  agent    Agent    @relation(fields: [requesterAgentId], references: [id])
  approver AppUser? @relation(fields: [approverUserId], references: [id])
  pos      PO[]
}

// ============================================================
// 9. FINANCE: SUPPLIERS, POs, PAYMENTS (RINA domain)
// ============================================================

model Supplier {
  id          String   @id @default(cuid())
  name        String
  whatsappNumber String?
  phone       String?
  address     String?
  contactPerson String?
  totalDebt   Float    @default(0) // running total hutang
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pos     PO[]
  payments SupplierPayment[]
}

model PO {
  id           String   @id @default(cuid())
  poNumber     String   @unique // e.g. PO-2026-001
  agentId      String   // RINA
  supplierId   String
  projectId    String?
  unitIds      String?  // JSON array of unit IDs (1 PO can cover multiple units)
  workItem     String?  // e.g. "Plaster", "Plesteran"
  status       String   @default("DRAFT") // DRAFT | PENDING_APPROVAL | APPROVED | SENT_TO_SUPPLIER | PARTIAL_DELIVERED | DELIVERED | PARTIAL_PAID | PAID | CANCELLED
  subtotal     Float    @default(0)
  totalAmount  Float    @default(0)
  notes        String?
  approvedAt   DateTime?
  sentAt       DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agent    Agent    @relation(fields: [agentId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  lines    POLine[]
  payments SupplierPayment[]
  approvalRecords Approval[]  // back-relation: approvals linked to this PO

  @@index([supplierId, status])
  @@index([status])
}

model POLine {
  id          String   @id @default(cuid())
  poId        String
  materialName String
  quantity    Float
  unitMeasure String   // zak | kg | m3 | btg | bh
  unitPrice   Float
  totalPrice  Float
  deliveredQuantity Float @default(0) // actual delivered (may differ from ordered)
  finalUnitPrice Float? // actual price at payment (may differ due to price change)
  notes       String?

  po PO @relation(fields: [poId], references: [id], onDelete: Cascade)
}

model SupplierPayment {
  id          String   @id @default(cuid())
  supplierId  String
  poId        String?
  amount      Float
  method      String   @default("TRANSFER") // TRANSFER | CASH | GIRO
  notes       String?
  approvalId  String?
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id])
  po       PO?       @relation(fields: [poId], references: [id])
}

model FundRequest {
  id           String   @id @default(cuid())
  agentId      String   // RINA
  requesterName String? // nama tukang/penerima
  type         String   // TUKANG_WAGE | OPERATIONAL | NOTARY | SLF | KWH | FUEL | SALARY | DP_REFUND | REIMBURSE | OTHER
  projectId    String?
  unitIds      String?  // JSON array
  description  String
  amount       Float
  status       String   @default("PENDING") // PENDING | APPROVED | REJECTED | PAID
  paidAt       DateTime?
  notes        String?
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agent    Agent    @relation(fields: [agentId], references: [id])
  approver AppUser? @relation(fields: [approvedBy], references: [id])
}

// ============================================================
// 10. MATERIAL MANAGEMENT (Material AI domain)
// ============================================================

model RAB {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  version     Int      @default(1)
  totalBudget Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines   RABLine[]
}

model RABLine {
  id            String   @id @default(cuid())
  rabId         String
  projectId     String
  workItem      String   // e.g. "Plasteran", "Plesteran"
  materialName  String
  quantity      Float
  unitMeasure   String
  unitPrice     Float
  totalPrice    Float
  supplierSuggestion String?
  createdAt     DateTime @default(now())

  rab     RAB     @relation(fields: [rabId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id])
}

model MaterialStock {
  id          String   @id @default(cuid())
  projectId   String
  materialName String
  unitMeasure String
  quantity    Float    @default(0)
  minimumStock Float   @default(0) // 10% threshold
  unitPrice   Float?
  lastRestockAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, materialName, unitMeasure])
}

model MaterialUsage {
  id          String   @id @default(cuid())
  unitId      String
  materialName String
  quantity    Float
  unitMeasure String
  workItem    String?  // which work item this was used for
  reportedBy  String?  // nama orang lapangan
  reportMethod String? // PHOTO | TEXT | VOICE
  photoUrl    String?
  notes       String?
  usedAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, usedAt])
}

model ProgressPhoto {
  id          String   @id @default(cuid())
  unitId      String
  workItem    String?
  photoUrl    String
  caption     String?
  takenBy     String?
  weekClosing String?  // e.g. "2026-W25" for Friday closing book
  takenAt     DateTime @default(now())
  createdAt   DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
}

model UnitBudgetTracking {
  id           String   @id @default(cuid())
  unitId       String
  workItem     String
  budgetAmount Float
  actualAmount Float    @default(0)
  usagePercent Float    @default(0) // computed: actual/budget
  isOverBudget Boolean  @default(false)
  warningSentAt DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, workItem])
}

// ============================================================
// 11. DOCUMENT MANAGEMENT (Document AI domain)
// ============================================================

model Document {
  id          String   @id @default(cuid())
  customerId  String?
  agentId     String?
  projectId   String?
  type        String   // KTP | NPWP | KK | AKTA_NIKAH | SLIP_GAJI | SK_KERJA | NIB | LABA_RUGI | BANK_FORM | BPHTB | NOTARY | OTHER
  bankName    String?  // BTN | MANDIRI | SUMSELBABEL | null if not bank-specific
  fileName    String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  extractedData String? // JSON of OCR/extracted fields
  status      String   @default("UPLOADED") // UPLOADED | EXTRACTED | FILLED_TEMPLATE | SIGNED | ARCHIVED
  notes       String?
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  agent    Agent?    @relation(fields: [agentId], references: [id])
  uploadedByUser AppUser? @relation(fields: [uploadedBy], references: [id])
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  bankName    String
  templateName String
  templateUrl String?
  fields      String?
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  type        String?
  category    String?
  sortOrder   Int?
  isRequired  Boolean?
  description String?
  mimeType    String?
  fileSize    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// 12. SURVEY SCHEDULING (Survey group)
// ============================================================

model SurveySchedule {
  id          String   @id @default(cuid())
  customerId  String
  agentId     String?
  scheduledAt DateTime
  duration    Int      @default(60) // minutes
  location    String?
  status      String   @default("SCHEDULED") // SCHEDULED | CONFIRMED | COMPLETED | CANCELLED | NO_SHOW
  assignedTo  String?  // nama human yang nemuin: Ayen / Desri / Owner
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  agent    Agent?    @relation(fields: [agentId], references: [id])
}

// ============================================================
// 13. AUDIT LOG (for RATNA to analyze & optimize)
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  agentId     String?
  action      String
  entityType  String?
  entityId    String?
  metadata    String?  // JSON
  ipAddress   String?
  createdAt   DateTime @default(now())

  user AppUser? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([agentId, createdAt])
}

// ============================================================
// 13b. PENDING ACTIONS (DINA confirmation flow)
// Critical: pendingAction was previously in-memory module-level state
// which is BROKEN on Vercel serverless — each request may run in a
// different lambda. Moving to DB for persistence + per-conversation isolation.
// ============================================================

model PendingAction {
  id              String   @id @default(cuid())
  conversationId  String?  // which conversation thread this belongs to
  customerId      String?  // optional: which customer this is about
  channel         String   @default("DASHBOARD") // DASHBOARD | WHATSAPP_PRIVATE | WHATSAPP_GROUP
  senderNumber    String?  // for WA: who initiated
  type            String   // DELETE | CREATE | UPDATE
  targetType      String   // CUSTOMER | FIELD
  targetId        String?  // customer id being deleted/updated
  targetName      String?  // human-readable target name
  fieldName       String?  // for UPDATE: which field
  newValue        String?  // for UPDATE: new value
  customerData    String?  // for CREATE: JSON of new customer data
  status          String   @default("PENDING") // PENDING | CONFIRMED | CANCELLED | EXPIRED
  createdAt       DateTime @default(now())
  expiresAt       DateTime // 5 minutes TTL
  confirmedAt     DateTime?

  @@index([conversationId, status])
  @@index([channel, senderNumber, status])
  @@index([expiresAt])
}

// ============================================================
// 13d. BANK CONFIG (Self-service bank template management)
// User can add new banks without AI code changes.
// Each bank has: name, templatePath, fields (JSON array of annotations)
// DINA can manage banks via chat (list, add, update, delete)
// ============================================================

model BankConfig {
  id            String   @id @default(cuid())
  bankCode      String   @unique // BTN, MANDIRI, BSB_SYARIAH, BCA, etc.
  bankName      String   // Display name: "BTN", "Mandiri", "BSB Syariah"
  description   String?  // Optional description
  templatePath  String?  // Path to PDF template (e.g. /templates/btn-flpp.pdf)
  documents     String?  // JSON array of document configs: [{ id, name, templatePath, fields: [...] }]
  isActive      Boolean  @default(true)
  createdBy     String?  // 'system' (migration) or 'dina' (via chat) or 'owner' (UI)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([bankCode])
}

model NotarisSetting {
  id        String   @id @default(cuid())
  name      String   // nama + gelar notaris
  address   String?
  city      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Company Setting (global - 1 record, id='default')
// Director info + bank account numbers per bank, shared across all customers
model CompanySetting {
  id              String   @id @default("default") // single global record
  companyName     String?  // Nama PT (Marlindo Bangun Persada)
  directorName    String?  // Nama Direktur (Andrian Bong)
  directorNik     String?  // NIK Direktur
  directorPhone   String?  // No. HP Direktur/Owner (global untuk semua tim Anjayo 16)
  directorAddress String?  // Alamat KTP Direktur (global)
  officeAddress   String?  // Alamat Kantor/Perusahaan (global)
  city            String?  // Kota (Pangkalpinang)
  btnAccount      String?  // No. Rekening BTN
  mandiriAccount  String?  // No. Rekening Mandiri
  bsbAccount      String?  // No. Rekening BSB Syariah
  btnBranch       String?  // Cabang BTN
  mandiriBranch   String?  // Cabang Mandiri
  bsbBranch       String?  // Cabang BSB
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  userId      String?
  agentId     String?
  type        String   // APPROVAL_NEEDED | NEW_LEAD | BUDGET_WARNING | STOCK_LOW | SURVEY_REMINDER | SYSTEM
  title       String
  message     String
  referenceType String?
  referenceId String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@index([agentId, isRead])
}

// ============================================================
// BANK PIPELINE - Track customer progress per bank
// ============================================================

model BankPipeline {
  id          String   @id @default(cuid())
  customerId  String
  bankName    String
  status      String   @default("NOT_SUBMITTED") // NOT_SUBMITTED | BERKAS_MASUK | PROSES_BANK | SP3K | AKAD
  submittedAt DateTime?
  sp3kAt      DateTime?
  akadAt      DateTime?
  rejectAt    DateTime?
  rejectReason String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, bankName])
  @@index([customerId])
}
